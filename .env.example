# Palestine House — environment variables (NAMES ONLY, no real values).
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit it, never put secrets in this file.
# Never place a server-only secret behind a NEXT_PUBLIC_* name.

# --- Public (browser-readable, build-time) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Added in later sprints (names only; leave blank / configure in Vercel) ---
# Supabase (Sprint 2/3) — public, browser-safe:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase — server-only secret (NEVER NEXT_PUBLIC_, NEVER in client code):
# SUPABASE_SECRET_KEY=
# Cloudflare Turnstile (public forms):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Email — Resend (S12: contact + support + approval/decline) — server-only:
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=          # e.g. hello@your-verified-domain — on the SPF/DKIM/DMARC-verified Resend sending domain
# RESEND_TO_EMAIL=            # inbox that receives contact + support messages
# Email — Mailchimp (S12: lead magnets, newsletter, apply tagging) — server-only:
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=    # API-key region suffix, e.g. us1 / us21 / eu1
# MAILCHIMP_AUDIENCE_ID=      # target audience (list) id
# Rate limiting (server-only):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
