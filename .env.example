# Palestine House — environment variables (NAMES ONLY, no real values).
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit it, never put secrets in this file.
# Never place a server-only secret behind a NEXT_PUBLIC_* name.

# --- Public (browser-readable, build-time) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Added in later sprints (names only; leave blank / configure in Vercel) ---
# Supabase (Sprint 2/3) — public, browser-safe:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase — server-only secret (NEVER NEXT_PUBLIC_, NEVER in client code):
# SUPABASE_SECRET_KEY=
# Cloudflare Turnstile (public forms):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Email + integrations (server-only):
# RESEND_API_KEY=
# MAILCHIMP_API_KEY=
# Rate limiting (server-only):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
